# Environment Variables Template
# Copy this file to .env and fill in your values
# DO NOT commit .env file to version control

# Server Configuration
SERVER_PORT=8080

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_database_name
DB_USERNAME=your_username
DB_PASSWORD=your_password

# JWT Configuration
# Generate using: openssl rand -base64 64
JWT_SECRET=your_base64_encoded_secret_key_here
JWT_EXPIRATION=86400000

# Google Authentication
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# OTP SMS Configuration
# Set to twilio to send real SMS, or log for local development
OTP_SMS_PROVIDER=twilio
# If true and provider=log, OTP is logged (no SMS). Keep false in real usage.
OTP_SMS_ALLOW_LOG_FALLBACK=false
# Used to normalize local phone formats like 0771234567 -> +94771234567
OTP_SMS_DEFAULT_COUNTRY_CODE=+94
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
# Must be a Twilio purchased/sender number in E.164 format (example: +1415XXXXXXX)
TWILIO_PHONE_NUMBER=+10000000000
