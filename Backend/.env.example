# Environment Variables Template
# Copy this file to .env and fill in your values
# DO NOT commit .env file to version control

# Server Configuration
SERVER_PORT=8080

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_database_name
DB_USERNAME=your_username
DB_PASSWORD=your_password

# JWT Configuration
# Generate using: openssl rand -base64 64
JWT_SECRET=your_base64_encoded_secret_key_here
JWT_EXPIRATION=86400000

# Google Authentication
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# OTP Email Configuration
# Set to smtp to send real OTP emails, or log for local development
OTP_EMAIL_PROVIDER=smtp
# If true and provider=log, OTP is logged (no email). Keep false in real usage.
OTP_EMAIL_ALLOW_LOG_FALLBACK=false
OTP_EMAIL_FROM=no-reply@your-domain.com

# SMTP Mail Configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
# For Gmail, use an App Password (not your account login password)
MAIL_PASSWORD=your_app_password
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
MAIL_SMTP_STARTTLS_REQUIRED=true
